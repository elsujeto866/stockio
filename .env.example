# Supabase project URL - safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://project-ref.supabase.co

# Supabase publishable key (sb_publishable_...) - browser-safe, RLS-respecting.
# Used by the browser client AND the server client that runs under the user session.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_placeholder

# Supabase secret key (sb_secret_...) - SERVER ONLY. Never prefix with NEXT_PUBLIC_.
# Bypasses RLS. Import ONLY from src/lib/supabase/admin.ts.
SUPABASE_SECRET_KEY=sb_secret_placeholder
