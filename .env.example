# Supabase project URL — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://project-ref.supabase.co

# Supabase anon key — RLS-gated, safe in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=anon-key-placeholder

# SERVICE ROLE KEY — SERVER ONLY. Never prefix with NEXT_PUBLIC_.
# Import ONLY from src/lib/supabase/admin.ts. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=service-role-key-placeholder
